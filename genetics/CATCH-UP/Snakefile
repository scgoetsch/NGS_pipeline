import os
import sys
import pandas as pd

from snakemake.utils import min_version
from snakemake.utils import validate

from workflow_utils import normalize_config, prepare_workflow_inputs

min_version("7.0.0")

configfile: "config/analysis.yaml"

config = normalize_config(config)
validate(config, schema="config/schema/config.schema.yaml")

if config["single_paired_end"] not in ["single", "paired"]:
    print("config['single_paired_end'] must be 'single' or 'paired'!")
    sys.exit()

workflow_inputs = prepare_workflow_inputs(config, workflow_dir=".")
origin_fastq = workflow_inputs["origin_fastq"]
origin_fastq_concat = workflow_inputs["origin_fastq_concat"]
samples_r = workflow_inputs["samples_r"]
merge_sample = workflow_inputs["merge_sample"]
concat_map = workflow_inputs["concat_map"]
merge_map = workflow_inputs["merge_map"]

genomeV = config["genome_built_version"]


def _is_placeholder_path(value):
    value = str(value or "").strip()
    return "<" in value or ">" in value


def build_track_base_url(config):
    """Return the base URL used in generated UCSC trackDb entries.

    If bigWigs are not explicitly copied to a public folder, point trackDb at
    the real local bigWig directory. Avoid propagating template placeholder
    paths such as <path-to-output-directory> into runnable analyses.
    """
    if (
        not config.get("move_bw_public_folder")
        or _is_placeholder_path(config.get("public_output_dir"))
        or _is_placeholder_path(config.get("tag_public_output_dir"))
    ):
        coverage_dir = os.path.abspath(config["analysis_name"] + os.sep + config["bam_coverage"])
        return "file://" + coverage_dir

    parts = [str(config["bigDataUrl"]).rstrip("/")]
    for key in ["public_output_dir", "tag_public_output_dir"]:
        value = str(config.get(key, "")).strip().strip("/")
        if value:
            parts.append(value)
    return "/".join(parts)


track_base_url = build_track_base_url(config)

analysis_samples = list(samples_r.index)
raw_read_samples = list(origin_fastq)
merge_samples = list(merge_sample)


def peak_log_targets():
    return [
        os.path.join(config["analysis_name"] + os.sep + config["peaks_log"], f"{sample}_{genomeV}.txt")
        for sample in merge_samples
    ]


def read_qc_targets():
    return [
        os.path.join(config["analysis_name"] + os.sep + config["reads_qc"], f"{sample}.html")
        for sample in raw_read_samples
    ]


def trimming_qc_targets():
    return [
        os.path.join(config["analysis_name"] + os.sep + config["trimming_qc"], f"{sample}_fastqc.txt")
        for sample in raw_read_samples
    ]


def aligner_multiqc_targets():
    return [
        os.path.join(config["analysis_name"] + os.sep + config["aligner_qc"], f"{sample}_{genomeV}_multiqc.html")
        for sample in analysis_samples
    ]


def duplicates_multiqc_targets():
    return [
        os.path.join(config["analysis_name"] + os.sep + config["duplicates_qc"], f"{sample}_{genomeV}_multiqc.html")
        for sample in analysis_samples
    ]


def merge_multiqc_targets():
    return [
        os.path.join(config["analysis_name"] + os.sep + config["merge_qc"], f"{sample}_{genomeV}_multiqc.html")
        for sample in merge_samples
    ]


def bam_coverage_targets():
    return [
        os.path.join(config["analysis_name"] + os.sep + config["bam_coverage"], f"{sample}_{genomeV}.bw")
        for sample in merge_samples
    ]


include: "rules/01_upstream.smk"
include: "rules/02_qc.smk"
include: "rules/03_trackDb.smk"
include: "rules/04_folders.smk"

if not config["cutadapters_bool"]:

    rule all:
        input:
            peak_log_targets(),
            read_qc_targets(),
            aligner_multiqc_targets(),
            duplicates_multiqc_targets(),
            merge_multiqc_targets(),
            os.path.join(config["analysis_name"] + os.sep + config["track"], "trackDb.txt"),
            os.path.join(config["analysis_name"] + os.sep + config["cleaning"], "moving.txt")
else:

    rule all:
        input:
            peak_log_targets(),
            read_qc_targets(),
            trimming_qc_targets(),
            aligner_multiqc_targets(),
            duplicates_multiqc_targets(),
            merge_multiqc_targets(),
            os.path.join(config["analysis_name"] + os.sep + config["track"], "trackDb.txt"),
            os.path.join(config["analysis_name"] + os.sep + config["cleaning"], "moving.txt")
